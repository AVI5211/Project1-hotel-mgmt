# Database Configuration
DATABASE_URL=postgresql://hotel_user:hotel_password@postgres:5432/hotel_db

# Server Configuration
PORT=5000

# JWT Secret (Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# Cloudinary Configuration (OPTIONAL - uses local storage if not configured)
# For local development, you can leave these empty and images will be stored in ./uploads
# For production, get credentials from: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
